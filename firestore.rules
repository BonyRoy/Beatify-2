rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Music collection
    match /music/{document} {
      allow read: if true;
      allow write: if true;
    }

    // Song Requests collection
    match /songRequests/{document=**} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if true;
    }

    // OTPs for song request validation
    match /songRequestOtps/{document} {
      allow read, write: if true;
    }

    // Accounts collection (for Create Account flow)
    match /accounts/{document} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if true;
    }

    // User listening stats (last 10 songs + top 3 artists per logged-in user)
    match /userListeningStats/{accountId} {
      allow read, create, update: if true;
    }

    // Notifications (song added alerts when admin marks request fulfilled)
    match /notifications/{document} {
      allow read, create, update, delete: if true;
    }

    // User feedback
    match /feedback/{document} {
      allow read, create: if true;
      allow update, delete: if true;
    }

    // Track play counts (global, per-track UUID)
    match /trackPlayCounts/{document} {
      allow read, create, update: if true;
    }

    // Admin settings (password etc.) - restrict in production
    match /adminSettings/{document} {
      allow read, write: if true;
    }

    // Admin session tokens - for session verification
    match /adminValidSessions/{document} {
      allow read, create, update, delete: if true;
    }

    // Playlists (name, image, trackIds)
    match /playlists/{document} {
      allow read: if true;
      allow create, update, delete: if true;
    }

  }
}
